generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int                   @id @default(autoincrement())
  telegramId   String                @unique
  firstName    String
  lastName     String?
  username     String?
  photoUrl     String?
  createdAt    DateTime              @default(now())
  role         String                @default("CUSTOMER")
  orders       Order[]
  dataOrders   DataOrder[]
  addresses    Address[]
  favorites    Favorite[]
  products     Product[]             @relation("CollaboratorProducts")
  earnings     CollaboratorEarning[]
}

model Address {
  id        Int     @id @default(autoincrement())
  userId    Int
  user      User    @relation(fields: [userId], references: [id])
  label     String
  street    String
  city      String
  zip       String
  isDefault Boolean @default(false)
  orders    Order[]
}

model Category {
  id       Int       @id @default(autoincrement())
  slug     String    @unique
  name     String
  order    Int
  products Product[]
}

model Product {
  id             Int                   @id @default(autoincrement())
  categoryId     Int?
  category       Category?             @relation(fields: [categoryId], references: [id])
  name           String
  description    String
  price          Float
  stock          Int                   @default(0)
  imageUrl       String
  images         String                @default("[]")
  isActive       Boolean               @default(true)
  collaboratorId Int?
  collaborator   User?                 @relation("CollaboratorProducts", fields: [collaboratorId], references: [id])
  orderItems     OrderItem[]
  favorites      Favorite[]
  cardInventory  CardInventory[]
}

model Order {
  id            Int                   @id @default(autoincrement())
  userId        Int
  user          User                  @relation(fields: [userId], references: [id])
  addressId     Int?
  address       Address?              @relation(fields: [addressId], references: [id])
  status        String                @default("PENDING")
  note          String?
  subtotal      Float
  deliveryFee   Float
  total         Float
  deliverySlot  String
  createdAt     DateTime              @default(now())
  items         OrderItem[]
  earnings      CollaboratorEarning[]
  cardInventory CardInventory[]
}

model OrderItem {
  id        Int                  @id @default(autoincrement())
  orderId   Int
  order     Order                @relation(fields: [orderId], references: [id])
  productId Int
  product   Product              @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  options   String               @default("{}")
  earning   CollaboratorEarning?
}

model CollaboratorEarning {
  id             Int       @id @default(autoincrement())
  orderId        Int
  order          Order     @relation(fields: [orderId], references: [id])
  orderItemId    Int       @unique
  orderItem      OrderItem @relation(fields: [orderItemId], references: [id])
  collaboratorId Int
  collaborator   User      @relation(fields: [collaboratorId], references: [id])
  amount         Float
  platformFee    Float
  createdAt      DateTime  @default(now())
}

model Favorite {
  id        Int     @id @default(autoincrement())
  userId    Int
  user      User    @relation(fields: [userId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}

model Setting {
  key   String @id
  value String
}

model CardInventory {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  fullData  String
  sold      Boolean  @default(false)
  orderId   Int?
  order     Order?   @relation(fields: [orderId], references: [id])
  createdAt DateTime @default(now())
}

model DataFile {
  id            Int          @id @default(autoincrement())
  name          String       @unique
  uploadedAt    DateTime     @default(now())
  hasNom        Boolean      @default(false)
  hasPrenom     Boolean      @default(false)
  hasNumero     Boolean      @default(false)
  hasDob        Boolean      @default(false)
  hasAdresse    Boolean      @default(false)
  hasCodePostal Boolean      @default(false)
  hasVille      Boolean      @default(false)
  hasEmail      Boolean      @default(false)
  hasIban       Boolean      @default(false)
  hasBic        Boolean      @default(false)
  ficheCount    Int          @default(0)
  numlistCount  Int          @default(0)
  maillistCount Int          @default(0)
  records       DataRecord[]
}

model DataRecord {
  id                  Int               @id @default(autoincrement())
  fileId              Int
  file                DataFile          @relation(fields: [fileId], references: [id], onDelete: Cascade)
  nom                 String?
  prenom              String?
  numero              String?
  dateNaissance       String?
  adresse             String?
  codePostal          String?
  ville               String?
  email               String?
  iban                String?
  bic                 String?
  bank                String?
  gender              String?
  department          String?
  inFiche             Boolean           @default(false)
  inNumlist           Boolean           @default(false)
  inMaillist          Boolean           @default(false)
  extractedAsFiche    Boolean           @default(false)
  extractedAsNumlist  Boolean           @default(false)
  extractedAsMaillist Boolean           @default(false)
  createdAt           DateTime          @default(now())
  orderRecords        DataOrderRecord[]
}

model DataOrder {
  id        Int               @id @default(autoincrement())
  userId    Int
  user      User              @relation(fields: [userId], references: [id])
  type      String
  status    String            @default("READY")
  withNames Boolean           @default(false)
  lineCount Int
  createdAt DateTime          @default(now())
  records   DataOrderRecord[]
  files     DataOrderFile[]
}

model DataOrderRecord {
  orderId  Int
  recordId Int
  order    DataOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  record   DataRecord @relation(fields: [recordId], references: [id])

  @@id([orderId, recordId])
}

model DataOrderFile {
  id         Int       @id @default(autoincrement())
  orderId    Int
  order      DataOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fileType   String
  filename   String
  content    String
  partNumber Int?
  createdAt  DateTime  @default(now())
}
