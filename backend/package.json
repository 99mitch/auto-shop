{
  "name": "backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start:prod": "prisma migrate deploy && node dist/prisma/seed.js && node dist/src/index.js",
    "build": "npm run build -w floramini-types && prisma generate && tsc",
    "start": "node dist/index.js",
    "test": "jest --runInBand",
    "seed": "tsx prisma/seed.ts",
    "seed:donnees": "tsx prisma/seed-donnees.ts",
    "migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "floramini-types": "*",
    "grammy": "^1.21.0",
    "jsonwebtoken": "^9.0.0",
    "xlsx": "^0.20.3",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "prisma": "^5.10.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
